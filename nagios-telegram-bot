        send_message "❌ *Error applying ACK to \`${host}\`.*
Details: ${error_detail}"
        log_msg "ERROR" "Failed to apply ACK: $host. Details: $error_detail"
    fi
}

# ==========================================
# 4. BOT CORE ROUTING & POLLING
# ==========================================

process_update() {
    local text="$1"
    
    local command=$(echo "$text" | awk '{print tolower($1)}')
    log_msg "INFO" "Received command: $command"

    case "$command" in
        /start|/help)
            show_help
            ;;
        /broadcast)
            local target_msg=$(echo "$text" | sed -e "s|^$command[[:space:]]*||")
            if [[ -z "$target_msg" ]]; then
                send_message "⚠️ *Invalid Format.*
Usage: \`/broadcast The message you want to send to the team\`"
            else
                broadcast_message "$target_msg" "$FIRST_NAME"
            fi
            ;;
        /hosts)
            send_message "Querying hosts..."
            get_hosts_down
            ;;
        /services)
            send_message "Querying services..."
            get_services_critical
            ;;
        /status)
            get_system_status
            ;;
        /perf)
            get_performance_data
            ;;
        /ack_host)
            local target_host=$(echo "$text" | awk -F'"' '{print $2}')
            local target_comment=$(echo "$text" | awk -F'"' '{print $3}' | xargs)
            
            if [[ -z "$target_host" ]]; then
                send_message "⚠️ *Invalid Format.*
Usage: \`/ack_host \"hostname\" Optional comment\`"
            else
                ack_host "$target_host" "$target_comment"
            fi
            ;;
        /ack_service)
            local target_host=$(echo "$text" | awk -F'"' '{print $2}')
            local target_service=$(echo "$text" | awk -F'"' '{print $4}')
            local target_comment=$(echo "$text" | awk -F'"' '{print $5}' | xargs)
            
            if [[ -z "$target_host" ]] || [[ -z "$target_service" ]]; then
                send_message "⚠️ *Invalid Format.*
Usage: \`/ack_service \"hostname\" \"service_name\" Optional comment\`"
            else
                ack_service "$target_host" "$target_service" "$target_comment"
            fi
            ;;
        /ping)
            send_message "🏓 Pong! The bot is fully operational."
            ;;
        /shutdown)
            log_msg "WARN" "Remote shutdown triggered via Telegram by $FIRST_NAME ($CHAT_ID)."
            send_message "⚙️ *Executing remote shutdown sequence...*"
            shutdown_sequence
            ;;
        *)
            log_msg "WARN" "Unknown command received: $command"
            send_message "❓ *Command not recognized.*
I did not understand the action \`$command\`.

👉 Type /help to see the available commands."
            ;;
    esac
}

bot_main_loop() {
    log_msg "INFO" "Starting main polling loop..."
    
    while true; do
        # Use a slightly longer timeout for curl than the long-poll query parameter
        local updates
        if ! updates=$(${CURL_EXEC} -m 35 "${TELEGRAM_API}/getUpdates?offset=${OFFSET}&timeout=${LONG_POLL_TIMEOUT}"); then
            log_msg "WARN" "Connection to Telegram API timed out or failed. Retrying..."
            sleep 5
            continue
        fi
        
        local update_count=$(echo "$updates" | jq '.result | length' 2>/dev/null)
        
        # If jq fails or returns null/empty
        if [[ -z "$update_count" ]]; then
            log_msg "WARN" "Failed to parse Telegram API response."
            sleep 2
            continue
        fi
        
        if [[ "$update_count" -gt 0 ]]; then
            for (( i=0; i<$update_count; i++ )); do
                local update_id=$(echo "$updates" | jq -r ".result[$i].update_id")
                CHAT_ID=$(echo "$updates" | jq -r ".result[$i].message.chat.id")
                FIRST_NAME=$(echo "$updates" | jq -r ".result[$i].message.chat.first_name")
                local text=$(echo "$updates" | jq -r ".result[$i].message.text")

                # Update offset safely
                OFFSET=$((update_id + 1))
                echo "$OFFSET" > "$OFFSET_FILE"

                [[ "$text" == "null" || -z "$text" ]] && continue

                if ! is_authorized "$CHAT_ID"; then
                    log_msg "WARN" "Unauthorized access attempt from Chat ID: ${CHAT_ID} (${FIRST_NAME})"
                    send_message "⛔ *Access Denied.*"
                    continue
                fi

                # Route the command
                process_update "$text"
            done
        fi
        sleep 1
    done
}

# ==========================================
# GRACEFUL SHUTDOWN HANDLING
# ==========================================

shutdown_sequence() {
    log_msg "INFO" "Termination signal received. Initiating graceful shutdown..."
    
    # 1. Forzar la confirmación del offset en la API de Telegram para evitar bucles de reinicio
    if [[ -n "$OFFSET" && "$OFFSET" -gt 0 ]]; then
        log_msg "INFO" "Flushing offset ($OFFSET) to Telegram API before exit..."
        $CURL_EXEC "${TELEGRAM_API}/getUpdates?offset=${OFFSET}" >/dev/null 2>&1
    fi
    
    # 2. Enviar mensaje de despedida a los administradores
    local shutdown_msg="🛑 *System Alert:* The bot is shutting down and will be offline."
    
    IFS=',' read -ra ADM_CHATS <<< "$ALLOWED_CHAT_IDS"
    for chat in "${ADM_CHATS[@]}"; do
        if [[ -n "$chat" ]]; then
            $CURL_EXEC -X POST "${TELEGRAM_API}/sendMessage" \
                --data-urlencode "chat_id=${chat}" \
                --data-urlencode "text=${shutdown_msg}" \
                --data-urlencode "parse_mode=Markdown" >/dev/null 2>&1
        fi
    done
    
    log_msg "INFO" "Cleanup complete. Exiting cleanly (0)."
    exit 0
}

# Trap SIGINT (Ctrl+C) and SIGTERM (systemctl stop) to run the shutdown_sequence
trap shutdown_sequence SIGINT SIGTERM

# ==========================================
# 5. INITIALIZATION & SETUP
# ==========================================

# Default Config Path
CONFIG_FILE="/etc/nagios-telegram-bot/config.env"
OFFSET_FILE="/etc/nagios-telegram-bot/bot_offset.txt"

# Argument Parsing
while [[ "$#" -gt 0 ]]; do
    case $1 in
        -f|--config)  CONFIG_FILE="$2"; shift ;;
        -V|--version) echo "nagios-telegram-bot v${VERSION}"; exit 0 ;;
        *) 
            echo "❌ Unknown parameter: $1"
            echo "Usage: $0 [-f|--config /path/to/config.env] [-V|--version]"
            exit 1 ;;
    esac
    shift
done

check_dependencies

if [[ ! -f "$CONFIG_FILE" ]]; then
    log_msg "FATAL" "Configuration file not found: $CONFIG_FILE"
    exit 1
fi

source "$CONFIG_FILE"

TELEGRAM_API="https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}"
NAGIOS_URL="${NAGIOS_URL%/}"

if [[ -f "$OFFSET_FILE" ]]; then
    OFFSET=$(cat "$OFFSET_FILE")
else
    OFFSET=0
fi

log_msg "INFO" "Initializing Nagios Telegram Bot with persistence at $OFFSET_FILE..."

# Startup Broadcast
IFS=',' read -ra ADM_CHATS <<< "$ALLOWED_CHAT_IDS"
for chat in "${ADM_CHATS[@]}"; do
    if [[ -n "$chat" ]]; then
        CHAT_ID="$chat"
        FIRST_NAME="Admin"
        send_message "🚀 *nagios-telegram-bot has been successfully started/restarted.*"
        show_help
    fi
done

# Clear globals
CHAT_ID=""
FIRST_NAME=""

# Launch Long Polling
bot_main_loop
