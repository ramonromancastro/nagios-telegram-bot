# Ensures the script doesn't mask pipeline errors
set -o pipefail

# ==========================================
# 0. GLOBAL CONSTANTS
# ==========================================
VERSION="1.1.2"
CURL_TIMEOUT=15
LONG_POLL_TIMEOUT=30
ITEMS_PER_MESSAGE=10
CURL_EXEC="curl -s -k -m ${CURL_TIMEOUT}"
DEBUG=0

# ==========================================
# 1. CORE FUNCTIONS (Logging & Checks)
# ==========================================

# Standardized logging function
log_msg() {
    local level="$1"
    shift
    local message="$*"
    local timestamp=$(date "+%Y-%m-%d %H:%M:%S")
    local log_output="[$timestamp] [$level] - $message"

    case "$level" in
        ERROR|FATAL) echo -e "\e[31m$log_output\e[0m" >&2 ;; # Red stderr
        WARN)        echo -e "\e[33m$log_output\e[0m" >&2 ;; # Yellow stderr
        DEBUG)       [[ $DEBUG -eq 1 ]] && echo -e "$log_output" ;; # Stdout if debug
        INFO|*)      echo -e "$log_output" ;; # Stdout normal
    esac
}

# Dependency checker
check_dependencies() {
    local deps=("curl" "jq" "awk")
    for dep in "${deps[@]}"; do
        if ! command -v "$dep" &> /dev/null; then
            log_msg "FATAL" "Required dependency '$dep' is not installed. Aborting."
            exit 1
        fi
    done
}

# ==========================================
# 2. TELEGRAM API INTERACTION
# ==========================================

send_message() {
    local text="$1"
    local response
    local ok err_code desc

    log_msg "INFO" "Sending message via Telegram API to Chat ID: ${CHAT_ID}..."
    
    # Send request and capture response
    if ! response=$($CURL_EXEC -X POST "${TELEGRAM_API}/sendMessage" \
        --data-urlencode "chat_id=${CHAT_ID}" \
        --data-urlencode "text=${text}" \
        --data-urlencode "parse_mode=Markdown" 2>/dev/null); then
        
        log_msg "ERROR" "Telegram API unreachable (Network/Timeout)."
        return 1
    fi
    
    # Validate response is valid JSON
    if ! echo "$response" | jq -e . >/dev/null 2>&1; then
        echo "[ERROR] Invalid JSON response from Telegram: $response" >&2
        return 1
    fi

    ok=$(echo "$response" | jq -r '.ok')
    if [[ "$ok" != "true" ]]; then
        err_code=$(echo "$response" | jq -r '.error_code')
        desc=$(echo "$response" | jq -r '.description')
        log_msg "ERROR" "Telegram API failed (Error $err_code): $desc"
        return 1
    else
        log_msg "INFO" "Message successfully delivered to Telegram."
        return 0
    fi
}

is_authorized() {
    local chat_id="$1"
    if [[ ",${ALLOWED_CHAT_IDS}," == *",${chat_id},"* ]]; then
        return 0
    else
        return 1
    fi
}

