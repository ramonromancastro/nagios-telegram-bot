    local csrf_token=$(echo "$form_html" | grep -i "nagFormId" | sed -E "s/.*VALUE=['\"]([^'\"]+)['\"].*/\1/i" | head -n 1)

    [[ -z "$csrf_token" ]] && log_msg "WARN" "Could not extract nagFormId for host. Command may fail."

    # STEP 2
